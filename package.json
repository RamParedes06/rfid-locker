{
  "name": "rfid-locker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build && tsc --project tsconfig.server.json",
    "start:new": "NODE_ENV=production node dist/server.js",
    "dev:new": "concurrently \"tsc --project tsconfig.server.json --watch --preserveWatchOutput\" \"nodemon --watch dist -x 'node dist/server.js'\""
  },
  "dependencies": {
    "hardware-controller-sdk": "github:aique2022/hardware-controller#uat",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.525.0",
    "next": "^14.2.32",
    "react": "^18",
    "react-dom": "^18",
    "sass": "^1.99.0",
    "socket.io": "^4.8.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.0",
    "nodemon": "^3.1.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
