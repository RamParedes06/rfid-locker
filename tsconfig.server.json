{
  "compilerOptions": {
    "target": "ES2017",
    "module": "node16",
    "moduleResolution": "node16",
    "lib": ["es2017"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["server.ts"],
  "exclude": ["node_modules", "dist", "app", "components", "lib"]
}
